{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    }
  },
  "2": {
    "class_type": "DownloadAndLoadFlorence2Model",
    "inputs": {
      "model": "microsoft/Florence-2-large",
      "precision": "float16",
      "attention": "sdpa"
    }
  },
  "3": {
    "class_type": "Florence2Run",
    "inputs": {
      "image": ["1", 0],
      "florence2_model": ["2", 0],
      "text_input": "",
      "task": "more_detailed_caption",
      "fill_mask": true,
      "keep_model_loaded": false,
      "max_new_tokens": 1024,
      "num_beams": 3,
      "do_sample": false
    }
  },
  "4": {
    "class_type": "OllamaGenerate",
    "inputs": {
      "prompt": ["3", 2],
      "url": "http://localhost:11434",
      "model": "impactframes/llama3_ifai_sd_prompt_mkr_q4km",
      "system_message": "You are a caption editor for LoRA training datasets. Refine this image description into a clean, natural caption suitable for AI training. Start with the trigger word 'TRIGGER_WORD'. Remove redundant phrases. Keep it under 100 words. Output only the refined caption.\n\nOriginal description: ",
      "keep_alive": false,
      "temperature": 0.5,
      "max_tokens": 512,
      "seed": 42
    }
  },
  "5": {
    "class_type": "ShowText|pysssss",
    "inputs": {
      "text": ["4", 0]
    }
  },
  "6": {
    "class_type": "SaveText|pysssss",
    "inputs": {
      "text": ["5", 0],
      "path": "lora_dataset",
      "filename_prefix": "caption",
      "extension": "txt",
      "append": false
    }
  }
}
